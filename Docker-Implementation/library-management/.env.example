BACKEND_IMAGE=your-dockerhub-username/library-backend:latest
FRONTEND_IMAGE=your-dockerhub-username/library-frontend:latest

# Internal MySQL container defaults
MYSQL_ROOT_PASSWORD=Pass@3110
MYSQL_DATABASE=library_db
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/library_db
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=Pass@3110

# If using external DB instead, replace SPRING_DATASOURCE_URL with:
# SPRING_DATASOURCE_URL=jdbc:mysql://your-db-host:3306/library_db
